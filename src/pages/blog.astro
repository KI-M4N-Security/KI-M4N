---
import Layout from '../layouts/Layout.astro';
---

<Layout title="BLOG | KI-M4N Operations">
  <main class="max-w-7xl mx-auto px-4 md:px-6 py-12 md:py-20">
    
    <!-- Blog Header -->
    <section class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-4 tracking-tighter uppercase font-mono">
        <span class="text-[#00FF00]">></span> OPERATOR'S LOG
      </h2>
      <p class="text-[#00FF00]/60 font-mono text-lg max-w-2xl mx-auto">
        Thoughts on <span class="text-white">cybersecurity</span>, <span class="text-white">physical security convergence</span>, and <span class="text-white">offensive operations</span>.
      </p>
    </section>

    <!-- Blog Posts Grid -->
    <div class="blog-grid">
      
      <!-- Blog Post 1 -->
      <article class="blog-card">
        <div class="blog-card-content">
          <div class="blog-date">2026-03-01</div>
          <h3 class="blog-title">THE CONVERGENCE: Where Physical Meets Digital</h3>
          <p class="blog-excerpt">
            Why modern security can't afford to treat physical and digital as separate domains. 
            Real-world scenarios where a door gap led to a network breach...
          </p>
          <a href="#" class="blog-link">READ_ENTRY →</a>
        </div>
      </article>

      <!-- Blog Post 2 -->
      <article class="blog-card">
        <div class="blog-card-content">
          <div class="blog-date">2026-02-15</div>
          <h3 class="blog-title">RED TEAM OPS: Lessons from the Field</h3>
          <p class="blog-excerpt">
            After 50+ penetration tests, here are the patterns that keep repeating. 
            The human element is always the weakest link...
          </p>
          <a href="#" class="blog-link">READ_ENTRY →</a>
        </div>
      </article>

      <!-- Blog Post 3 -->
      <article class="blog-card">
        <div class="blog-card-content">
          <div class="blog-date">2026-02-01</div>
          <h3 class="blog-title">ESP32 WARDRIVING: The Captive Portal</h3>
          <p class="blog-excerpt">
            Building a rogue access point for educational purposes. 
            How easy is it to harvest credentials in a public space? The answer might surprise you...
          </p>
          <a href="#" class="blog-link">READ_ENTRY →</a>
        </div>
      </article>

      <!-- Blog Post 4 -->
      <article class="blog-card">
        <div class="blog-card-content">
          <div class="blog-date">2026-01-20</div>
          <h3 class="blog-title">FROM SECURITAS TO CYBERSECURITY</h3>
          <p class="blog-excerpt">
            My journey from leading physical security teams to mastering ethical hacking. 
            The skills that translated and the ones that didn't...
          </p>
          <a href="#" class="blog-link">READ_ENTRY →</a>
        </div>
      </article>

      <!-- Blog Post 5 -->
      <article class="blog-card">
        <div class="blog-card-content">
          <div class="blog-date">2026-01-05</div>
          <h3 class="blog-title">AI & LLM IN OFFENSIVE OPERATIONS</h3>
          <p class="blog-excerpt">
            Using Claude, GPT, and local LLMs for vulnerability research and payload generation. 
            The good, the bad, and the Skynet scenarios...
          </p>
          <a href="#" class="blog-link">READ_ENTRY →</a>
        </div>
      </article>

      <!-- Blog Post 6 -->
      <article class="blog-card">
        <div class="blog-card-content">
          <div class="blog-date">2025-12-20</div>
          <h3 class="blog-title">TOOLS OF THE TRADE: 2026 EDITION</h3>
          <p class="blog-excerpt">
            My current toolkit for red team operations. 
            From Cobalt Strike to custom Python scripts - what's in the arsenal...
          </p>
          <a href="#" class="blog-link">READ_ENTRY →</a>
        </div>
      </article>

    </div>

    <!-- More Posts Coming Soon -->
    <div class="mt-16 text-center p-8 border border-[#00FF00]/20 bg-[#00FF00]/5 rounded-lg">
      <p class="text-[#00FF00] font-mono text-sm tracking-widest">
        <span class="animate-pulse">●</span> NEW_ENTRIES_UPLOADING_SOON...
      </p>
    </div>

  </main>
</Layout>

<style>
  /* Blog Grid */
  .blog-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .blog-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .blog-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Blog Card */
  .blog-card {
    position: relative;
    border-radius: 4px;
    background: rgba(5, 5, 5, 0.29);
    min-height: 220px;
    color: white;
    font-family: 'Fira Code', monospace;
    border: 1px solid rgba(0, 255, 0, 0.2);
    transition: all 0.3s ease;
  }

  .blog-card:hover {
    border-color: #00FF00;
    box-shadow: 0 0 25px -5px #00FF00;
    transform: translateY(-5px);
  }

  .blog-card-content {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 1.5rem;
    background: linear-gradient(180deg, rgba(20,20,20,0.5) 0%, rgba(0,0,0,0) 100%);
  }

  .blog-date {
    font-size: 0.7rem;
    color: #00FF00/60;
    margin-bottom: 0.75rem;
    font-family: 'Fira Code', monospace;
    letter-spacing: 0.1em;
  }

  .blog-title {
    font-size: 1rem;
    font-weight: bold;
    color: white;
    margin-bottom: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    line-height: 1.3;
    transition: color 0.3s;
  }

  .blog-card:hover .blog-title {
    color: #00FF00;
    text-shadow: 0 0 10px #00FF00;
  }

  .blog-excerpt {
    font-size: 0.8rem;
    line-height: 1.5;
    color: #aaa;
    flex-grow: 1;
    margin-bottom: 1rem;
  }

  .blog-link {
    margin-top: auto;
    background-color: transparent;
    color: #00FF00;
    font-size: 0.75rem;
    text-transform: uppercase;
    padding: 0.5rem 0;
    text-decoration: none;
    border: none;
    transition: all 0.3s ease;
    font-weight: bold;
    display: inline-block;
  }

  .blog-link:hover {
    color: white;
    text-shadow: 0 0 10px #00FF00;
    padding-left: 0.5rem;
  }

  /* Mobile adjustments */
  @media (max-width: 640px) {
    .blog-card {
      min-height: auto;
    }
    
    .blog-title {
      font-size: 0.9rem;
    }
    
    .blog-excerpt {
      font-size: 0.75rem;
    }
  }
</style>
